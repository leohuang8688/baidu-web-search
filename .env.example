# Baidu Web Search API Configuration
# Get your API key from: https://ai.baidu.com/

BAIDU_API_KEY=your_baidu_api_key_here

# Tavily Search API Configuration
# Get your API key from: https://app.tavily.com (1,000 free credits/month)

TAVILY_API_KEY=your_tavily_api_key_here

# Search Provider Selection (optional)
# Values: baidu | tavily
# If not set, Tavily is used when TAVILY_API_KEY is present, otherwise Baidu.
# SEARCH_PROVIDER=tavily

# Instructions:
# 1. Replace API key placeholders with your actual keys
# 2. Save this file
# 3. The skill will automatically load this configuration
